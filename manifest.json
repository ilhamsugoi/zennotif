{
  "manifest_version": 3,
  "name": "ZenNotif - Zendesk Ticket Notifier",
  "version": "5.0",
  "description": "Sound notifications for new Zendesk tickets. No API token required.",
  "permissions": [
    "alarms",
    "storage",
    "notifications",
    "offscreen"
  ],
  "host_permissions": [
    "https://*.zendesk.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://*.zendesk.com/*"],
      "js": ["content.js"]
    }
  ],
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "ZenNotif",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png"
    }
  },
  "web_accessible_resources": [
    {
      "resources": ["notifikasi.mp3", "icon.png"],
      "matches": ["<all_urls>"]
    }
  ],
  "offscreen": {
    "pages": ["offscreen.html"],
    "reasons": ["AUDIO_PLAYBACK"],
    "justification": "Required to play ticket notification sounds."
  }
}